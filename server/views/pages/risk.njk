{% extends "../partials/case.njk" %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "../_components/predictor-timeline/macro.njk" import predictorTimelineV1 %}
{% from "../_components/predictor-score/macro.njk" import predictorScore %}
{% from "../_components/predictor-timeline-item/macro.njk" import predictorTimelineItem %}

{% set currentNavSection = 'risk' %}
{% set currentSectionName = 'Risk' if not sentencePlan.showLink and not sentencePlan.showText else 
    'Risk and plan' %}
{% set riskPage = true %}
{% set pageTitle = makePageTitle({pageHeading: currentSectionName}) %}
{% set headerCRN = crn %}
{% set headerDob = personRisks.personSummary.dateOfBirth %}
{% set headerGender = personRisks.personSummary.gender %}
{% set hasRiskAssessment = risks.assessedOn %}
{% if risks.assessedOn %}
    {% set lastUpdatedDate = 'Last updated: ' + risks.assessedOn | dateWithYear %}
{% endif %}

{% if sentencePlan.showLink or sentencePlan.showText %}
    {% set scoresHeadingLevel = '4' %}
    {% set scoresSubHeadingLevel = '5' %}

{% endif %}
{% if sanIndicator %}
    {% set scoresHeadingClass = 's' %}
{% endif %}

{% set identifiedNeeds %}
{% if needs.identifiedNeeds.length %}
    <ul class="govuk-list">
        {% for need in needs.identifiedNeeds %}
            <li>
                {{ need.name }}
            </li>
        {% endfor %}
    </ul>
{% else %}
        None
    {% endif %}
{% endset %}

{% set notIdentifiedNeeds %}
{% if needs.notIdentifiedNeeds.length %}
    <ul class="govuk-list">
        {% for need in needs.notIdentifiedNeeds %}
            <li>
                {{ need.name }}
            </li>
        {% endfor %}
    </ul>
{% else %}
        None
    {% endif %}
{% endset %}

{% set unansweredNeeds %}
{% if needs.unansweredNeeds.length %}
    <ul class="govuk-list">
        {% for need in needs.unansweredNeeds %}
            <li>
                {{ need.name }}
            </li>
        {% endfor %}
    </ul>
{% else %}
        None
    {% endif %}
{% endset %}

{% block beforeContent %}
    {{ govukBreadcrumbs({
        items: [
            {
                text: "Cases",
                href: "/case"
            },
            {
                text: headerPersonName.forename + ' ' + headerPersonName.surname,
                href: "/case/" + crn,
                attributes: { "data-ai-id": "breadcrumbPersonNameLink" }
            },
            {
                text: currentSectionName
            }
        ]
    }) }}
{% endblock %}

{% block pageContent %}
    <div class="govuk-grid-row govuk-!-margin-top-4">
        {% if not sanIndicator %}
            {% include "./risk/_risk-page.njk" %}
        {% else %}
            {% include "./risk/_risk-page-san-indicator.njk" %}
        {% endif %}
    </div>
{% endblock %}