{% extends "../_form.njk" %}
{% set title = 'Enforcement action for ' + appointmentOutcome.forename + '’s failure to comply' %}
{% set backLink = '/case/' + crn + '/appointments' %}
{% set initiateText = 'Initiate a ' + (
'breach' if sentenceType == 'COMMUNITY' else 
  'recall'
) %}

{% block form %}
  {{ govukRadios({
    name: "enforcementAction",
    fieldset: {
      legend: {
        text: "Select an action for " + appointmentOutcome.forename + "’s failure to comply",
        isPageHeading: false,
        classes: "govuk-fieldset__legend--m"
      }
    },
    items: [
      {
        value: "SEND_LETTER",
        text: "Send a letter"
      },
      {
        value: "BREACH_RECALL_INITIATED",
        text: initiateText
      }  if sentenceType in ['COMMUNITY', 'CUSTODY'],
      {
        value: "BREACH_RECALL_INITIATED_AND_SEND_LETTER",
        text: initiateText + " and send a letter"
      }  if sentenceType in ['COMMUNITY', 'CUSTODY'],
      {
        value: "REFER_TO_OFFENDER_MANAGER",
        text: "Refer to probation practitioner",
        hint: {
          text: "Notify the allocated probation practitioner so they can take action."
        }
      } if not isProbationPractitioner,
      {
        value: "NO_FURTHER_ACTION",
        text: "No further action"
      },
      {
        divider: "or"
      },
      {
        value: "DIFFERENT_ACTION",
        text: "I want to add a different action"
      }
    ]
  } | decorateFormAttributes(['appointments', appointmentOutcome.crn, appointmentOutcome.id,  'outcome', 'enforcementAction'])) }}
{% endblock %}