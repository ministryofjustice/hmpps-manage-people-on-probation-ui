{% extends "../_form.njk" %}
{% set notStandardForm = true %}
{% set title = 'Check your answers then confirm the appointment' if not appointment.isReschedule else
  'Change appointment details and reschedule' %}
  {% set pageTitle = makePageTitle({
  pageHeading: [title, "Arrange appointment"]
}) %}
{% set rescheduleApptInsertText = "You'll receive a calendar invite for the appointment." if not appointment.isReschedule else
  "You'll receive an updated calendar invite for the appointment." %}
{% set buttonText = 'Confirm this appointment' if not appointment.isReschedule else
  'Reschedule appointment' %}
{% set showCalendarInsetText = not isInPast %}
{% if appointment.isReschedule %}
  {% set showAnchorLink = true %}
  {% set formAnchorLink = "/case/" + crn + "/appointments/reschedule/" + contactId + "/" + id %}
  {% set formAnchorText = 'Cancel and go back' %}
{% endif %}
{% block beforeContent %}{% endblock %}
{% block primary %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-l" data-qa="pageHeading">{{ title }}</h2>
      {% if appointment.isReschedule %}
        <p class="govuk-body">Use the saved details of the previously created appointment to reschedule it. You can amend any of the details.</p>
      {% endif %}
    </div>
  </div>
  {% include "./appointment-summary.njk" %}

{% endblock %}
