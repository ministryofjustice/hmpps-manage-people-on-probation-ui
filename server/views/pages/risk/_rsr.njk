{% if flags.enableOGRS4 %}
    {% set band_ogrs4 = riskData
        .assessments[0]
        .combinedSeriousReoffendingPredictor
        .band %}
    {% set band_ogrs3 = riskData
        .assessments[0]
        .rsr
        .band %}
    {% set showOGRS4 = true if band_ogrs4 and band_ogrs4 != "NOT APPLICABLE" else 
        false %}
    {% set showOGRS3 = true if band_ogrs3 and band_ogrs3 != "NOT APPLICABLE" else 
        false %}

    {% if showOGRS4 %}
        <section data-qa="combinedSeriousReoffendingPredictor">
            {{ predictorScale({
    data: riskData,
    predictor: "combinedSeriousReoffendingPredictor"
      }) }}
        </section>
    {% endif %}
    {% if showOGRS3 %}
        <section data-qa="rsr">
            {{ predictorScale({
    data: riskData,
    predictor: "rsr"
      }) }}
        </section>
    {% endif %}
{% else %}
    {% if predictorScores.scores.RSR.score %}
        <section data-qa="rsr">
            <h{{ scoresHeadingLevel if scoresHeadingLevel else '3'  }} class="govuk-heading-{{ scoresHeadingClass if scoresHeadingClass else 'm'  }} score-header govuk-!-margin-bottom-0" data-analytics-event-scroll="RSR score">
        RSR (risk of serious recidivism)
    </h {{ scoresHeadingLevel if scoresHeadingLevel else '3'  }}>
            <div aria-hidden="true">
                {{ predictorScore(predictorScores.scores.RSR) }}
            </div>
            <div class='govuk-visually-hidden'>Score: {{ predictorScores.scores.RSR.score }}%</div>
        </section>
    {% endif %}
{% endif %}