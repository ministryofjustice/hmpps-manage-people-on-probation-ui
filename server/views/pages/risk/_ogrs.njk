{% if predictorScores.scores.OGRS.level %}
    <section data-qa="ogrs">
        {{ predictorScale(
            {
            level: predictorScores.scores.OGRS.level,
            score: predictorScores.scores.OGRS.oneYear,
            type: predictorScores.scores.OGRS.type,
            staticOrDynamic: predictorScores.scores.OGRS.staticOrDynamic | upper,
            lastUpdated: predictorScores.date
        },
        true,
        true,
        true
    )}}
    </section>
{% endif %}