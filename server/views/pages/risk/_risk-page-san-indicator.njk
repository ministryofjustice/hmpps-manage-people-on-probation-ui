<div class="govuk-grid-column-two-thirds">
    {% if hasRiskAssessment %}
        {% include './_risk-scores-card.njk' %}
    {% else %}
        {% set html %}
        <h3 class="govuk-heading-m">There is no OASys Layer 3 risk assessment for {{ personRisks.personSummary.name | fullName }}</h3>
        {% include './_no-oasys-risk-assessment.njk' %}
        {% endset %}
        {{ govukNotificationBanner({ html: html, attributes: { 'data-qa': 'noOasysRiskBanner' } }) }}
    {% endif %}
    {% include './_opd.njk' %}
    {% include './_risk-flags.njk' %}
</div>

<div class="govuk-grid-column-one-third">
    {% include './_rosh.njk' %}
    {% include './_mappa.njk' %}
    {% include './_sentence-plan.njk' %}
</div>