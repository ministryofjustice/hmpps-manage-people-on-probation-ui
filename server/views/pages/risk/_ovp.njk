{% set band_ogrs4 = riskData
  .assessments[0]
  .violentReoffendingPredictor
  .band %}
{% set band_ogrs3 = riskData
  .assessments[0]
  .ovp
  .band %}
{% set showOGRS4 = true if band_ogrs4 and band_ogrs4 != "NOT APPLICABLE" else 
  false %}
{% set showOGRS3 = true if band_ogrs3 and band_ogrs3 != "NOT APPLICABLE" else 
  false %}

{% if showOGRS4 %}
  <section data-qa="violentReoffendingPredictor">
    {% if flags.enableOGRS4SummaryCardDetail %}
      <div class="arns-summary-card-expanded-badge-spacing">
        {{ expandedPredictorBadge({
            data: riskData,
            predictor: "violentReoffendingPredictor",
            excludeDate: true,
            fixedWidth: false
          }) }}
      </div>
    {% else %}
      {{ predictorScale({
        data: riskData,
        predictor: "violentReoffendingPredictor",
        excludeDate: true,
        headingLevel: 4,
        headingClass: "xs"
      }) }}
    {% endif %}
  </section>
{% endif %}
{% if showOGRS3 %}
  <section data-qa="ovp">
    {{ predictorScale({
      data: riskData,
      predictor: "ovp",
      excludeDate: true,
      headingLevel: 4,
      headingClass: "xs"
    }) }}
  </section>
{% endif %}