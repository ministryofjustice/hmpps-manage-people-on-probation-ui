{% if flags.enableOGRS4 %}
  {% set band_ogrs4 = riskData
    .assessments[0]
    .seriousViolentReoffendingPredictor
    .band %}
  {% set band_ogrs3 = riskData
    .assessments[0]
    .snsv
    .band %}
  {% set showOGRS4 = true if band_ogrs4 and band_ogrs4 != "NOT APPLICABLE" else 
    false %}
  {% set showOGRS3 = true if band_ogrs3 and band_ogrs3 != "NOT APPLICABLE" else 
    false %}

  {% if showOGRS4 %}
    <section data-qa="seriousViolentReoffendingPredictor">
      {% if flags.enableOGRS4SummaryCardDetail %}
        {{ expandedPredictorBadge({
            data: riskData,
            predictor: "seriousViolentReoffendingPredictor",
            excludeDate: true,
            fixedWidth: false
          }) }}
      {% else %}
        {{ predictorScale({
          data: riskData,
          predictor: "seriousViolentReoffendingPredictor",
          excludeDate: true,
          headingLevel: 4,
          headingClass: "xs"
        }) }}
      {% endif %}
    </section>
  {% endif %}
  {% if showOGRS3 %}
    <section data-qa="snsv">
      {{ predictorScale({
        data: riskData,
        predictor: "snsv",
        excludeDate: true,
        headingLevel: 4,
        headingClass: "xs"
      }) }}
    </section>
  {% endif %}
{% else %}
  {% if predictorScores.scores.SNSV.level %}
    <section data-qa="snsv">
      <h{{ scoresHeadingLevel | default('3') }} class="govuk-heading-{{ scoresHeadingClass if scoresHeadingClass else 'm'  }} score-header govuk-!-margin-bottom-1" data-analytics-event-scroll="SNSV score">
        SNSV (Serious non-sexual violence predictor score)
    </h{{ scoresHeadingLevel | default('3') }}>
      <div class="govuk-grid-row  govuk-!-margin-bottom-4">
        <div class="govuk-grid-column-full">
          <div class="flex-mobile">
            <div class='flex__item-one-third-mobile'>
              <h{{ scoresSubHeadingLevel | default('4') }} class='govuk-heading-s govuk-!-margin-bottom-1'>1 year</h{{ scoresSubHeadingLevel | default('4') }}>
              <div class='govuk-body' data-qa='snsv-1yr'>{{ predictorScores.scores.SNSV.oneYear }}%</div>
            </div>
            <div class='flex__item-one-third-mobile'>
              <h{{ scoresSubHeadingLevel | default('4') }} class='govuk-heading-s govuk-!-margin-bottom-1'>2 year</h{{ scoresSubHeadingLevel | default('4') }}>
              <div class='govuk-body' data-qa='snsv-2yr'>{{ predictorScores.scores.SNSV.twoYears }}%</div>
            </div>
            <div class='flex__item-one-third-mobile'>
              <h{{ scoresSubHeadingLevel | default('4') }} class='govuk-heading-s govuk-!-margin-bottom-1'>Level</h{{ scoresSubHeadingLevel | default('4') }}>
              <div class='govuk-body' data-qa='snsv-level'>{{ riskLevelLabel(predictorScores.scores.SNSV.level) }}</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  {% endif %}
{% endif %}