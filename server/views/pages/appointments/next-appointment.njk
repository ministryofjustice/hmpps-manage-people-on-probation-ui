{% extends "../_form.njk" %}
{% set title = personAppointment.personSummary.name.forename + "’s next supervision appointment" %}
{% set pageTitle = makePageTitle({
  pageHeading: [title]
}) %}
{% set appointmentDisplayName = personAppointment.appointment.displayName or personAppointment.appointment.description or personAppointment.appointment.type %}
{% set sentence = appointment.appointmentFor.sentence %}
{% set backLink = back if back else
  '/case/' + crn + '/appointments/appointment/' + id + '/manage/' %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

{% set config = {
   formGroup: {
      attributes: {
        'data-qa': 'anotherAppointment'
      }
    },
    fieldset: {
      legend: {
        text: 'Do you want to arrange another appointment with ' + personAppointment.personSummary.name.forename + '?',
        classes: "govuk-fieldset__legend--m"
      }
    },
    errorMessage: {
    text: "Select if you want to arrange the next appointment"
  } if errorMessages.nextAppointment,
    items: [
    {
        text: ("Yes - another " + appointmentDisplayName) | toSentenceCase,
        value: "KEEP_TYPE",
        checked: body.nextAppointment == "KEEP_TYPE"
    },
    {
        text: "Yes - another appointment type",
        value: "CHANGE_TYPE",
        checked: body.nextAppointment == "CHANGE_TYPE"
    },
        {
        text: "No",
        value: "NO",
        checked: body.nextAppointment == "NO"
    }]
} %}
{% if not outcomeJourney %}
  {% set config = config | merge({id: "nextAppointment", idPrefix: "nextAppointment", name: "nextAppointment"}) %}
{% endif %}
{% if outcomeJourney %}
  {% set config = config | decorateFormAttributes(['appointments', crn, id, 'outcome', 'nextAppointment']) %}
{% endif %}

{% block afterHeading %}
  {% set nextAppointmentText = 'There are no upcoming supervision appointments for ' + personAppointment.personSummary.name.forename + '’s ' + sentence + '.' %}
  {% if nextAppointment.appointment %}
    {% set nextAppointmentText = appointmentDisplayName | toSentenceCase + " on " + nextAppointment.appointment.startDateTime | dateWithDayAndWithYear + " at " + nextAppointment.appointment.startDateTime | govukTime + " with " + nextAppointment.appointment.officer.name | fullName + " for their " + sentence %}
  {% endif %}
  {{ govukInsetText({
    html: nextAppointmentText
  }) }}
{% endblock %}
{% block form %}
  {{ govukRadios(config) }}
{% endblock %}
