{% extends "../../_form.njk" %}
{%- from "govuk/components/tag/macro.njk" import govukTag -%}

{% set title = "Online check in missed" %}
{% set backLink = back | default('/case/' + crn + '/activity-log') %}
{% set hideButton = true %}

{% block content %}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

        {% include "../../../partials/pop-header.njk" %}
        <hr class="govuk-section-break--l">

        {% if errorMessages %}
          {% set errorList = errorMessages | toErrorList %}
          {% if errorList.length > 0 %}
            {{ govukErrorSummary({
                titleText: "There is a problem",
                errorList: errorList,
                attributes: { "data-qa": "errorList"}
            }) }}
          {% endif %}
        {% endif %}
        <div class="govuk-grid-column-two-thirds govuk-!-padding-0">
            {% block heading %}
            {% if title %}
                <h2 class="govuk-heading-l govuk-!-margin-bottom-6" data-qa="pageHeading">
                {{ title }}
                </h2>
            {% endif %}
            {% endblock %}

            <form method="post" autocomplete="off" action="{{ paths.current  }}">
                {{ govukCharacterCount({
                    label: {
                        text: "Why did " + checkIn.personalDetails.name.forename + " not complete their check in?",
                        classes: "govuk-label--m"
                    },
                    hint: {
                        text: "For example, the person did not have access to a device."
                    },
                    rows: '10',
                    maxlength: maxCharCount,
                    formGroup: {
                        attributes: { "data-qa": "notes"}
                    }
                } | decorateFormAttributes(['esupervision', crn, id, 'checkins', 'missedCheckinComment'])) }}
                {{ govukRadios({
                    fieldset: {
                        legend: {
                            text: 'Does this online check in include sensitive information?',
                            classes: "govuk-fieldset__legend govuk-fieldset__legend--m"
                        }
                    },
                    hint: {
                        text: 'This is information that you believe must be recorded but not shared with a person on probation. If they make a request for their record, the Data Protection Team will decide whether the information can be shared.'
                    },
                    formGroup: {
                        attributes: {
                            'data-qa': 'sensitiveContact'
                        }
                    },
                    items: [
                        {
                            value: true,
                            text: "Yes, it includes sensitive information"
                        },
                        {
                            value: false,
                            text: "No, it is not sensitive"
                        }
                    ]
                } | decorateFormAttributes(['esupervision', crn, id, 'checkins', 'sensitiveContact'])) }}

                <div class="govuk-button-group">
                    {{ govukButton({
                    html: "Complete review",
                    attributes: {
                        'data-qa': 'submit-btn'
                    }
                    }) }}
                </div>
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            </form>
        </div>
    </div>
</div>

{% endblock %}
