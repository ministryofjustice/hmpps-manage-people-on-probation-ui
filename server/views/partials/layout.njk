{% block head %}
  <link href="/assets/css/app.css?{{ version }}" rel="stylesheet"/>
  {% if feComponents.cssIncludes %}
    {% for css in feComponents.cssIncludes %}
      <link href="{{ css }}" nonce="{{ cspNonce }}" rel="stylesheet"/>
    {% endfor %}
  {% else %}
    <link href="/assets/css/fallback_prob_fe_app_header.css" nonce="{{ cspNonce }}" rel="stylesheet"/>
    <link href="/assets/css/fallback_prob_fe_app_footer.css" nonce="{{ cspNonce }}" rel="stylesheet"/>
  {% endif %}
  <!-- BEGIN Optimal Intercept Snippet --> 
  <div class='owInviteSnippet' id='owInviteSnippet'> 
    <div class='owInviteMessage' id='owInviteMessage'> Got a spare 5 minutes to help us improve our website? </div>
    <a class='owInviteOk' id='owInviteOk' href='https://c8ht4lmd.optimalworkshop.com/treejack/hx0ain7i?tag=intercept&utm_medium=intercept&recording=false' target='_blank' rel='noopener noreferrer' > I'll do it </a> 
    <a class='owInviteCancel' id='owInviteCancel' href='javascript:void(0)' > No thanks </a> 
  </div> 
  <script nonce="{{ cspNonce }}"> 
    (function() { 
      function show() { 
        setTimeout(function() { 
          var inviteSnippet = document.getElementById('owInviteSnippet'); 
          inviteSnippet.style.display = 'block'; 
          inviteSnippet.style.opacity = 1; 
        }, 2000); 
      }
      function dismiss() { 
        var date = new Date(); 
        date.setMonth(date.getMonth() + 1); 
        document.cookie = 'ow-intercept-treejack-etjdsmsh = Done; path=/; expires = ' + date.toUTCString() + ';'; 
        document.getElementById('owInviteSnippet').style.display = 'none'; 
      } 
      function init() { 
        document.getElementById('owInviteSnippet').addEventListener('click', function(e) { 
          if (e.target.tagName === 'A') { 
            dismiss(); 
          } 
        });
        if (document.cookie.indexOf('ow-intercept-treejack-etjdsmsh') === -1) { 
          var request = new XMLHttpRequest(); 
          request.onloadend = function() { 
            try { 
              if (this.response && JSON.parse(this.response).active === true) { 
                show(); 
              } 
            } catch(e) {} 
          }; 
          request.open('POST', 'https://app.optimalworkshop.com/survey_status/treejack/etjdsmsh/active');
          request.send(); 
        } 
      } 
      if (document.readyState === 'complete') { 
        init(); 
      } else { 
        window.addEventListener('load', init); 
      } 
    })(); 
  </script> 
  <!-- END Optimal snippet -->
{% endblock %}

{% block pageTitle %}{{pageTitle | default(applicationName)}}
{% endblock %}

{% block header %}
  {% include "./prob_fe_header.njk" %}
  {% block banner %}{% endblock %}

{% endblock %}

{% block bodyStart %} <a id="top"></a> {% endblock %}

{% block footer %}
  {% if not hideSurveyUsefulSections %}
    {% include "./_survey-useful.njk" %}
  {% endif %}
  {% include "./prob_fe_footer.njk" %}
{% endblock %}
{% block bodyEnd %}
  {% if sentry and sentry.loaderScriptId %}
    <script nonce="{{ cspNonce }}">
      window.sentryOnLoad = function () {
        Sentry.init({
          release: "hmpps-manage-people-on-probation-ui@{{ version }}",
          environment: "{{ sentry.environment }}",
          tracesSampleRate: {{ sentry.tracesSampleRate }},
          replaysSessionSampleRate: {{ sentry.replaySampleRate }},
          replaysOnErrorSampleRate: {{ sentry.replayOnErrorSampleRate }},
          initialScope: {
            user: {
              username: "{{ user.username }}"
            }
          }
        });
      };
    </script>
    <script src="https://js.sentry-cdn.com/{{ sentry.loaderScriptId }}.min.js" nonce="{{ cspNonce }}" crossorigin="anonymous"></script>
  {% endif %}
  <script src="/assets/js/jquery.min.js"></script>
  <script type="module" src="/assets/js/app.js"></script>
  {% if feComponents.jsIncludes %}
    {% for js in feComponents.jsIncludes %}
      <script  type="module" src="{{ js }}" nonce="{{ cspNonce }}"></script>
    {% endfor %}
  {% else %}
    <script  type="module" src="/assets/js/fallback_prob_fe_app.js" nonce="{{ cspNonce }}"></script>
  {% endif %}
  <script nonce="{{ cspNonce }}">
    window.csrfToken = "{{ csrfToken }}";
  </script>
  <script nonce="{{ cspNonce }}">
    document.addEventListener('DOMContentLoaded', function () {
      document.initialiseTelemetry('{{ applicationInsightsConnectionString | default(' ') }}', '{{ applicationInsightsRoleName }}', '{{ user.username }}')
    })
  </script>
  <script nonce="{{ cspNonce }}">
    {% if validMimeTypes %}window.validMimeTypes = '{{ validMimeTypes }}'{% endif %}
    {% if maxFileSize %}window.maxFileSize = {{ maxFileSize }}{% endif %}
    {% if fileUploadLimit %}window.fileUploadLimit = {{ fileUploadLimit }}{% endif %}
  </script>
{% endblock %}