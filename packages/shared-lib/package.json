{
  "name": "@ministryofjustice/manage-people-on-probation-shared-lib",
  "version": "1.0.0",
  "description": "Shared assets for the Manage People on Probation application",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./middleware": "./dist/middleware/index.js",
    "./controllers": "./dist/controllers/index.js",
    "./mocks": "./dist/contollers/mocks/index.js",
    "./services": "./dist/services/index.js",
    "./data": "./dist/data/index.js",
    "./utils": "./dist/utils/index.js",
    "./properties": "./dist/properties/index.js"
  },
  "typesVersions": {
    "*": {
      "middleware": [
        "dist/middleware/index.d.ts"
      ],
      "controllers": [
        "dist/controllers/index.d.ts"
      ],
      "mocks": [
        "dist/controllers/mocks/index.d.ts"
      ],
      "services": [
        "dist/services/index.d.ts"
      ],
      "data": [
        "dist/data/index.d.ts"
      ],
      "utils": [
        "dist/utils/index.d.ts"
      ],
      "properties": [
        "dist/properties/index.d.ts"
      ],
      "types": [
        "dist/types/index.d.ts"
      ]
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc --build tsconfig.build.json && npm run copy-assets",
    "copy-assets": "copyfiles -u 1 src/technicalUpdates.json dist",
    "pack:install": "npm run build && TARBALL=$(npm pack) && cp \"$TARBALL\" ~/code/hmpps-appointments-service-ui/"
  },
  "dependencies": {
    "@flipt-io/flipt-client": "^0.14.0",
    "@microsoft/applicationinsights-clickanalytics-js": "^3.3.9",
    "@microsoft/applicationinsights-web": "^3.3.9",
    "@ministryofjustice/frontend": "^6.0.0",
    "@ministryofjustice/hmpps-audit-client": "^1.0.0",
    "@ministryofjustice/hmpps-probation-integration-e2e-tests": "^1.120.0",
    "@ministryofjustice/probation-search-frontend": "^2.4.0",
    "agentkeepalive": "^4.2.0",
    "applicationinsights": "^2.0.0",
    "bunyan": "^1.8.0",
    "bunyan-format": "^0.2.0",
    "compression": "^1.7.4",
    "connect-flash": "^0.1.1",
    "connect-redis": "^6.0.0",
    "cookie-session": "^2.0.0",
    "csrf-sync": "^4.2.1",
    "csurf": "^1.11.0",
    "express": "^5.1.0",
    "express-prom-bundle": "^8.0.0",
    "express-session": "^1.18.1",
    "helmet": "^6.0.0",
    "http-errors": "^2.0.0",
    "jsonwebtoken": "^9.0.0",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.23",
    "luxon": "3.7.2",
    "luxon-business-days": "^3.0.1",
    "multer": "2.0.2",
    "nocache": "^2.0.0",
    "nunjucks": "^3.2.0",
    "passport": "^0.6.0",
    "passport-oauth2": "^1.6.1",
    "postcode-validator": "^3.10.5",
    "prom-client": "^15.1.3",
    "redis": "^4.0.0",
    "slugify": "^1.6.0",
    "superagent": "^8.0.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@ministryofjustice/eslint-config-hmpps": "^0.0.4",
    "@sentry/node": "^7.0.0",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/connect-flash": "^0.0.40",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jwt-decode": "^2.2.1",
    "@types/lodash": "^4.17.24",
    "@types/luxon-business-days": "^3.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/passport": "^1.0.17",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.32.0",
    "babel-jest": "^30.1.2",
    "copyfiles": "^2.4.1",
    "jest": "^30.1.3",
    "jest-html-reporter": "^4.3.0",
    "jest-junit": "^16.0.0",
    "nock": "^13.0.0",
    "node-mocks-http": "^1.17.2",
    "prettier": "^3.5.3",
    "prettier-plugin-jinja-template": "^2.1.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.2",
    "typescript": "^5.8.3"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  }
}
